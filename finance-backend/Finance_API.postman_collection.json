{
  "info": {
    "name": "Finance Data Backend",
    "description": "Complete API collection for Finance Data Processing and Access Control Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "analystToken", "value": "" },
    { "key": "viewerToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"analyst\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('adminToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@finance.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Analyst)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('analystToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"analyst@finance.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Viewer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('viewerToken', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@finance.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users (Admin Only)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "role", "value": "analyst", "disabled": true },
                { "key": "status", "value": "active", "disabled": true },
                { "key": "search", "value": "jane", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update User Role & Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/users/REPLACE_WITH_USER_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"analyst\",\n  \"status\": \"active\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Financial Records",
      "item": [
        {
          "name": "Create Record (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/records",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"date\": \"2025-03-01\",\n  \"notes\": \"March salary credit\"\n}"
            }
          }
        },
        {
          "name": "Get All Records (Analyst)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{analystToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/records?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "expense", "disabled": true },
                { "key": "category", "value": "Groceries", "disabled": true },
                { "key": "startDate", "value": "2025-01-01", "disabled": true },
                { "key": "endDate", "value": "2025-03-31", "disabled": true },
                { "key": "search", "value": "salary", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Record (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/records/REPLACE_WITH_RECORD_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5500,\n  \"notes\": \"Updated amount after bonus\"\n}"
            }
          }
        },
        {
          "name": "Delete Record (Admin - Soft)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/records/REPLACE_WITH_RECORD_ID"
          }
        },
        {
          "name": "[403] Viewer tries to read records",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{viewerToken}}" }],
            "url": "{{baseUrl}}/records"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Summary (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/dashboard/summary"
          }
        },
        {
          "name": "Get Summary (Viewer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{viewerToken}}" }],
            "url": "{{baseUrl}}/dashboard/summary"
          }
        }
      ]
    }
  ]
}
